# =============================================================
# Mealie Recipe Parser — Configuration
# =============================================================
# Copy this file to .env and fill in your values.

# -------------------------------------------------------------
# LLM — Recipe JSON parsing (OpenAI-compatible API)
# Works with OpenRouter, OpenAI, or any compatible endpoint.
# -------------------------------------------------------------
OPENAI_API_KEY=sk-or-your-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Model used for parsing transcript+description into recipe JSON.
# Must support text input. Recommended: google/gemini-2.5-flash
OPENAI_MODEL=google/gemini-2.5-flash

# -------------------------------------------------------------
# Transcription — Fallback (OpenAI-compatible API)
# Used when local Whisper is unavailable or times out.
# Must support audio input (e.g. Gemini models via OpenRouter).
# -------------------------------------------------------------
# Model used for audio transcription fallback.
# Recommended: google/gemini-2.5-flash (supports audio via OpenRouter)
TRANSCRIPTION_MODEL=google/gemini-2.5-flash

# -------------------------------------------------------------
# Transcription — Local Whisper Server (optional)
# If set, will be tried first before the remote fallback.
# Must expose an OpenAI-compatible /v1/audio/transcriptions endpoint.
# -------------------------------------------------------------
# URL to your local Whisper server (leave empty to skip)
WHISPER_API_URL=http://192.168.1.100:8080/v1/audio/transcriptions
# How long to wait (ms) for local Whisper before falling back to remote
WHISPER_TIMEOUT_MS=15000
# Set to true to skip local Whisper entirely and always use remote transcription
SKIP_LOCAL_WHISPER=false

# -------------------------------------------------------------
# Mealie Instance
# -------------------------------------------------------------
MEALIE_URL=http://mealie.yourdomain.local:9925
# Long-lived API token — create one at: Mealie → Profile → API Tokens
MEALIE_API_TOKEN=mea_your_token_here

# -------------------------------------------------------------
# Server
# -------------------------------------------------------------
PORT=3000
